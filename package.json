{
  "name": "ds-forge",
  "version": "0.1.0",
  "description": "Lightweight agent harness for DeepSeek V4 models",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "deepseek",
    "agent",
    "tool-calling",
    "mcp",
    "llm"
  ],
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck:tui": "tsc --noEmit -p tsconfig.tui.json",
    "demo": "tsx --env-file-if-exists=.env examples/demo.ts",
    "demo:mcp": "tsx --env-file-if-exists=.env examples/mcp_demo.ts",
    "test": "npm run test:unit && npm run test:legacy",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:legacy": "tsx examples/mcp_test.ts && tsx examples/skills_test.ts && tsx examples/agents_md_test.ts && tsx tui/tui_test.ts",
    "tui": "tsx --env-file-if-exists=.env tui/index.tsx",
    "dev": "tsx --env-file-if-exists=.env"
  },
  "dependencies": {
    "openai": "^4.0.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.29",
    "ink": "^5.2.1",
    "react": "^18.3.1",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "3.2.6"
  },
  "overrides": {
    "vite": "6.4.3"
  }
}
